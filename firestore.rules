rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTaskParticipant(resourceData) {
      return request.auth.uid == resourceData.assignedTo
        || resourceData.assignedTo == 'both'
        || request.auth.uid == resourceData.requestedBy;
    }

    function validTaskCreate() {
      let d = request.resource.data;
      return d.requestedBy == request.auth.uid
        && d.title is string
        && d.title.size() > 0
        && d.isCompleted == false
        && d.keys().hasAll(['title', 'requestedBy', 'assignedTo', 'isCompleted']);
    }

    function taskUpdateAllowed() {
      // requestedBy and createdAt are immutable
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return !changed.hasAny(['requestedBy', 'createdAt']);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create: if signedIn() && validTaskCreate();
      allow update: if signedIn() && isTaskParticipant(resource.data) && taskUpdateAllowed();
      allow delete: if signedIn() && isTaskParticipant(resource.data);
    }

    match /dateIdeas/{ideaId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    match /dateHistory/{entryId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    match /goals/{goalId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn();
    }
  }
}
